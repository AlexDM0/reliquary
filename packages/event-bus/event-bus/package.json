{
  "name": "@reliquary/event-bus",
  "version": "0.3.0",
  "description": "A tiny, fully type-safe event bus with optional, swappable shared state. Zero dependencies, ships ESM + CJS.",
  "type": "module",
  "license": "MIT",
  "author": "Alex de Mulder",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "check:exports": "attw --pack . && publint",
    "release:npm": "bun publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "publint": "^0.3.0",
    "tsdown": "^0.15.6",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
