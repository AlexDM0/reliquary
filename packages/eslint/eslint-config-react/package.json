{
  "name": "@reliquary/eslint-config-react",
  "version": "1.0.0",
  "description": "React + Jest + Testing Library ESLint rules — the React layer for @reliquary/eslint-config.",
  "type": "module",
  "license": "MIT",
  "author": "Alex de Mulder",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "flat-config",
    "react",
    "jest",
    "testing-library"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": "./index.js"
  },
  "main": "./index.js",
  "files": [
    "index.js"
  ],
  "scripts": {
    "lint": "eslint index.js",
    "check:exports": "publint",
    "release:npm": "bun publish"
  },
  "peerDependencies": {
    "@reliquary/eslint-config": "workspace:^",
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "eslint-plugin-jest": "^28.0.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-testing-library": "^6.2.0"
  },
  "devDependencies": {
    "@reliquary/eslint-config": "workspace:*",
    "eslint": "^9.0.0",
    "publint": "^0.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
